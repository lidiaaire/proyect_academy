{
  "name": "elevate-your-english-backend",
  "version": "1.0.0",
  "description": "API REST para Elevate Your English | Campus LMS",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "seed": "node src/seeds/index.js",
    "test": "jest --runInBand",
    "test:watch": "jest --watch"
  },
  "jest": {
    "testEnvironment": "node",
