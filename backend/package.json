{
  "name": "elevate-your-english-backend",
  "version": "1.0.0",
  "description": "API REST para Elevate Your English | Campus LMS",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "seed": "node src/seeds/index.js",
    "lint": "eslint src/",
    "test": "jest --runInBand",
    "test:watch": "jest --watch"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.js"
    ],
    "verbose": true,
    "setupFiles": [
      "./tests/setup/env.js"
    ]
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.3.1",
    "express-validator": "^7.1.0",
    "js-yaml": "^5.2.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.5.1",
    "pdfkit": "^0.19.1",
    "qrcode": "^1.5.4",
    "swagger-ui-express": "^5.0.1"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "eslint": "^8.57.0",
    "jest": "^30.4.2",
    "mongodb-memory-server": "^11.2.0",
    "nodemon": "^3.1.4",
    "supertest": "^7.2.2"
  }
}
